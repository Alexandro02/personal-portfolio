---
import { profile } from "@data/site";
---

<section id="contact" class="py-24 px-6 max-w-2xl mx-auto text-center reveal">
  <h2 class="text-3xl mb-4" data-i18n-es="Contacto" data-i18n-en="Contact">Contacto</h2>
  <p class="opacity-70 mb-8" data-i18n-es="¿Tienes un proyecto en mente o quieres platicar? Escríbeme." data-i18n-en="Have a project in mind or just want to chat? Reach out.">
    ¿Tienes un proyecto en mente o quieres platicar? Escríbeme.
  </p>
  <div class="flex flex-wrap gap-3 justify-center">
    <a href={`mailto:${profile.email}`} class="btn btn-primary rounded-none font-mono uppercase tracking-wide" data-i18n-es="Escríbeme" data-i18n-en="Email me">Escríbeme</a>
    {profile.linkedin && (
      <a href={profile.linkedin} target="_blank" rel="noopener noreferrer" class="btn btn-outline rounded-none font-mono uppercase tracking-wide">
        LinkedIn
      </a>
    )}
    {profile.github && (
      <a href={profile.github} target="_blank" rel="noopener noreferrer" class="btn btn-outline rounded-none font-mono uppercase tracking-wide">
        GitHub
      </a>
    )}
  </div>
</section>
