  </button>
</div>

<script>
  const LANG_KEY = "lang";
  const THEME_KEY = "theme";
  const THEME_LABELS: Record<string, { dark: string; light: string }> = {
    es: { dark: "Oscuro", light: "Claro" },
    en: { dark: "Dark", light: "Light" },
  };

  function currentLang(): string {
    return localStorage.getItem(LANG_KEY) || "es";
  }

  function updateThemeLabel() {
    const label = document.querySelector<HTMLElement>("[data-theme-label]");
    if (!label) return;
    const theme = document.documentElement.getAttribute("data-theme") === "infra-light" ? "light" : "dark";
    // Label shows the theme clicking will switch TO (same convention as the language toggle).
    const target = theme === "light" ? "dark" : "light";
    label.textContent = THEME_LABELS[currentLang()][target];
  }

  function applyLang(lang: string) {
    document.documentElement.lang = lang;
    document.querySelectorAll<HTMLElement>("[data-i18n-es]").forEach((el) => {
      const text = lang === "en" ? el.dataset.i18nEn : el.dataset.i18nEs;
      if (text !== undefined) el.textContent = text;
    });
    const label = document.querySelector<HTMLElement>("[data-lang-label]");
    if (label) label.textContent = lang === "es" ? "English" : "Español";
    updateThemeLabel();
    window.dispatchEvent(new CustomEvent("langchange", { detail: { lang } }));
  }

  const storedLang = localStorage.getItem(LANG_KEY) || "es";
  applyLang(storedLang);

  document.querySelector("[data-lang-toggle]")?.addEventListener("click", () => {
    const current = localStorage.getItem(LANG_KEY) || "es";
    const next = current === "es" ? "en" : "es";
    localStorage.setItem(LANG_KEY, next);
    applyLang(next);
  });

  function applyTheme(theme: string) {
    document.documentElement.setAttribute("data-theme", theme);
    updateThemeLabel();
  }

  const storedTheme = document.documentElement.getAttribute("data-theme") || "infra";
  applyTheme(storedTheme);

  document.querySelector("[data-theme-toggle]")?.addEventListener("click", () => {
    const current = document.documentElement.getAttribute("data-theme") === "infra-light" ? "infra-light" : "infra";
    const next = current === "infra" ? "infra-light" : "infra";
    localStorage.setItem(THEME_KEY, next);
    applyTheme(next);
  });
</script>
